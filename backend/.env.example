# ─── backend/.env.example ─────────────────────────────────────────────────────
# Copy this to backend/.env (or inject via Railway / VPS env vars).
# These variables are BACKEND ONLY — never expose them to the frontend.

# ─── Argens (AI / scraping) ───────────────────────────────────────────────────
# Required for URL analysis and the curated idea feed.
# ARGENS_API_KEY never leaves the backend.
ARGENS_API_KEY=argns_live_...

# Confirmed base URL — do not change
ARGENS_API_BASE_URL=https://api.argens.xyz/v1

# Endpoint ID of your chosen LLM provider (NOT the provider id — the endpoint id).
# Discover: GET /api/admin/argens/llm-providers (needs ADMIN_TOKEN below)
# Enable the provider at https://argens.xyz/dashboard/marketplace, then set this.
ARGENS_LLM_SERVICE_ID=

# Firecrawl scrape endpoint — confirmed, usually no need to change
ARGENS_SCRAPE_SERVICE_ID=firecrawl_scrape

# Set to "1" to skip real Argens calls and return a canned idea (offline/local dev)
ARGENS_MOCK=

# ─── Database (LibSQL / Turso) ────────────────────────────────────────────────
# Local dev:       file:./data.db    (SQLite, no auth token needed)
# Production:      libsql://your-db-name.turso.io  (Turso remote)
#
# WARNING: file:./data.db is wiped on every redeploy on Railway/VPS without
# a persistent volume. Use Turso remote for production.
TURSO_DATABASE_URL=file:./data.db
TURSO_AUTH_TOKEN=

# ─── Payments (LemonSqueezy — consumer $1 unlock) ────────────────────────────
# This is for validating incoming webhooks. The $1 checkout is LemonSqueezy,
# NOT Argens. Never route the unlock payment through Argens.
LEMONSQUEEZY_WEBHOOK_SECRET=ophunt

# ─── Feed worker ─────────────────────────────────────────────────────────────
# Set to "1" to enable the background idea-feed scheduler on startup.
FEED_ENABLED=1

# How often the worker runs (in hours). Default: 24
FEED_INTERVAL_HOURS=24

# Max items analyzed per run. Bounds Argens USDC spend (each item ≈ 1-2 calls).
FEED_MAX_ITEMS_PER_RUN=15

# Product Hunt API v2 token (optional — feed skips Product Hunt if not set)
PRODUCT_HUNT_TOKEN=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# CORS: comma-separated list of allowed origins beyond localhost.
# Example for a split deploy: ALLOWED_ORIGINS=https://ophunt.vercel.app
ALLOWED_ORIGINS=

# Guards /api/admin/* endpoints. Set a long random string.
ADMIN_TOKEN=change-me-in-production

# ─── frontend/.env.example ────────────────────────────────────────────────────
# Copy this to frontend/.env (or set in Vercel project settings).
# The frontend has NO secrets — only the backend API URL.

# URL of your backend API.
# - Local dev: leave empty (Vite proxy handles /api → localhost:4100)
# - Vercel deploy: set to your Railway / VPS backend URL, e.g.:
#   VITE_API_URL=https://api.ophunt.io
# All API calls go to {VITE_API_URL}/api/...
VITE_API_URL=

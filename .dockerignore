# Dependencies — always reinstalled inside the image
node_modules
backend/node_modules
frontend/node_modules

# Build artifacts
backend/dist
frontend/dist
frontend/.vite

# Local SQLite DB — use Turso remote in production
backend/data.db
backend/data/

# Dev environment files — never bake secrets into the image
.env
backend/.env
frontend/.env
**/.env.local
**/.env.development

# Editor / OS noise
.DS_Store
.git
.gitignore
*.log
